# ─────────────────────────────────────────────────────────────────────────────
# Sanity CMS — get these from sanity.io/manage after creating your project
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: Sanity API token (needed for server-side draft previews or mutations)
# Create a token with Viewer permissions at sanity.io/manage
SANITY_API_READ_TOKEN=your_read_token_here

# ─────────────────────────────────────────────────────────────────────────────
# Contact Form — Resend email service (resend.com)
# ─────────────────────────────────────────────────────────────────────────────
# Get your API key from resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# The email address where NIL inquiry form submissions should be sent
CONTACT_EMAIL=kaylee@example.com

# The verified sender domain/address in Resend (must be a verified sender)
CONTACT_FROM_EMAIL=noreply@yourdomain.com
